@model LoginViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Login";
}

<div class="login-page">
    <div class="login-card">
        <div class="login-header">
            <div class="login-icon"><i class="fa fa-graduation-cap"></i></div>
            <h1>Student Record System</h1>
            <p>Sign in to continue</p>
        </div>

        <form asp-action="Login" asp-controller="Account" method="post" id="loginForm">
            <input type="hidden" asp-for="ReturnUrl" />
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-group">
                <label asp-for="Username"><i class="fa fa-user"></i> Username</label>
                <input asp-for="Username" class="form-control" placeholder="Enter your username" autocomplete="username" />
                <span asp-validation-for="Username" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password"><i class="fa fa-lock"></i> Password</label>
                <div class="input-with-icon">
                    <input asp-for="Password" class="form-control" placeholder="Enter your password" autocomplete="current-password" id="pwdInput" />
                    <button type="button" class="toggle-pwd" onclick="togglePwd()"><i class="fa fa-eye" id="eyeIcon"></i></button>
                </div>
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-full">
                <i class="fa fa-right-to-bracket"></i> Sign In
            </button>
        </form>

        
    </div>
</div>

@section Scripts {
<script>
function togglePwd() {
    const inp = document.getElementById('pwdInput');
    const icon = document.getElementById('eyeIcon');
    if (inp.type === 'password') { inp.type = 'text'; icon.className = 'fa fa-eye-slash'; }
    else { inp.type = 'password'; icon.className = 'fa fa-eye'; }
}
</script>
}
