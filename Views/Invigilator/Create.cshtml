@model CreateStudentViewModel
@{
    ViewData["Title"] = "Add Student";
}

<div class="page-header">
    <div>
        <h1><i class="fa fa-user-plus"></i> Add New Student</h1>
        <p class="text-muted">Fill in the details to create a student record.</p>
    </div>
    <a href="/Invigilator/Dashboard" class="btn btn-outline"><i class="fa fa-arrow-left"></i> Back</a>
</div>

<div class="form-card">
    <form asp-action="Create" asp-controller="Invigilator" method="post" id="createForm">
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <!-- Basic Info -->
        <div class="form-section">
            <h3><i class="fa fa-id-card"></i> Student Information</h3>
            <div class="form-group">
                <label asp-for="Name"><i class="fa fa-user"></i> Full Name <span class="required">*</span></label>
                <input asp-for="Name" class="form-control" placeholder="Enter student name (max 30 chars)" maxlength="30" />
                <div class="char-counter"><span id="nameLen">0</span>/30</div>
                <span asp-validation-for="Name" class="field-error"></span>
            </div>
        </div>

        <!-- Marks -->
        <div class="form-section">
            <h3><i class="fa fa-book"></i> Marks (1 – 100)</h3>
            <div class="marks-grid">
                <div class="form-group">
                    <label asp-for="Maths"><i class="fa fa-square-root-variable"></i> Maths <span class="required">*</span></label>
                    <input asp-for="Maths" type="number" class="form-control mark-input" min="1" max="100" placeholder="1-100" />
                    <span asp-validation-for="Maths" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Physics"><i class="fa fa-atom"></i> Physics <span class="required">*</span></label>
                    <input asp-for="Physics" type="number" class="form-control mark-input" min="1" max="100" placeholder="1-100" />
                    <span asp-validation-for="Physics" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Chemistry"><i class="fa fa-flask"></i> Chemistry <span class="required">*</span></label>
                    <input asp-for="Chemistry" type="number" class="form-control mark-input" min="1" max="100" placeholder="1-100" />
                    <span asp-validation-for="Chemistry" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="English"><i class="fa fa-book-open"></i> English <span class="required">*</span></label>
                    <input asp-for="English" type="number" class="form-control mark-input" min="1" max="100" placeholder="1-100" />
                    <span asp-validation-for="English" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Programming"><i class="fa fa-code"></i> Programming <span class="required">*</span></label>
                    <input asp-for="Programming" type="number" class="form-control mark-input" min="1" max="100" placeholder="1-100" />
                    <span asp-validation-for="Programming" class="field-error"></span>
                </div>
            </div>

            <!-- Live Total Preview -->
            <div class="marks-preview">
                <span>Live Preview — Total: <strong id="previewTotal">—</strong> | Average: <strong id="previewAvg">—</strong> | Grade: <strong id="previewGrade">—</strong></span>
            </div>
        </div>

        <!-- Optional Login Account -->
        <div class="form-section optional-section">
            <h3><i class="fa fa-key"></i> Student Login Account <span class="optional-label">Optional</span></h3>
            <p class="text-muted">Create a login account so this student can view their own record.</p>
            <div class="marks-grid">
                <div class="form-group">
                    <label asp-for="Username">Username</label>
                    <input asp-for="Username" class="form-control" placeholder="e.g. john_doe" />
                    <span asp-validation-for="Username" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Password">Password</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Min 6 characters" />
                    <span asp-validation-for="Password" class="field-error"></span>
                </div>
            </div>
        </div>

        <div class="form-actions">
            <a href="/Invigilator/Dashboard" class="btn btn-outline">Cancel</a>
            <button type="submit" class="btn btn-primary"><i class="fa fa-save"></i> Create Student Record</button>
        </div>
    </form>
</div>

@section Scripts {
<script>
// Character counter
const nameInput = document.querySelector('input[name="Name"]');
const nameLen   = document.getElementById('nameLen');
if (nameInput) {
    nameInput.addEventListener('input', () => { nameLen.textContent = nameInput.value.length; });
}

// Live marks preview
const markInputs = document.querySelectorAll('.mark-input');
markInputs.forEach(i => i.addEventListener('input', updatePreview));

function updatePreview() {
    const vals = Array.from(markInputs).map(i => parseInt(i.value) || 0);
    const total = vals.reduce((a, b) => a + b, 0);
    const avg   = total / 5;
    const grade = avg >= 90 ? 'A+' : avg >= 80 ? 'A' : avg >= 70 ? 'B' : avg >= 60 ? 'C' : avg >= 50 ? 'D' : 'F';
    document.getElementById('previewTotal').textContent = total;
    document.getElementById('previewAvg').textContent   = avg.toFixed(1);
    document.getElementById('previewGrade').textContent = grade;
}
</script>
}
